{
  "openapi": "3.0.3",
  "info": {
    "title": "NSTSF Actions API",
    "version": "1.0.0",
    "description": "Actions for NSTSF case notes, draft emails and document archiving."
  },
  "servers": [
    {
      "url": "https://willowy-parfait-a287e5.netlify.app"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "TodoItem": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "status": { "type": "string" },
          "dueDate": { "type": "string" },
          "owner": { "type": "string" },
          "notes": { "type": "string" }
        }
      },
      "ChangeOrderItem": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "amount": { "type": "string" },
          "status": { "type": "string" },
          "notes": { "type": "string" }
        }
      },
      "DocumentLink": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "date": { "type": "string" },
          "url": { "type": "string" },
          "fileId": { "type": "string" },
          "mimeType": { "type": "string" },
          "notes": { "type": "string" },
          "fileName": { "type": "string" },
          "contentText": { "type": "string" },
          "contentBase64": { "type": "string" }
        }
      },
      "DraftAttachment": {
        "type": "object",
        "properties": {
          "fileName": { "type": "string" },
          "mimeType": { "type": "string" },
          "contentBase64": { "type": "string" }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/meeting-package": {
      "post": {
        "operationId": "saveMeetingPackage",
        "summary": "Save meeting notes and archive related files to the case",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customerName", "noteText"],
                "properties": {
                  "caseNumber": { "type": "string" },
                  "actorName": { "type": "string" },
                  "actorEmail": { "type": "string" },
                  "customerName": { "type": "string" },
                  "source": { "type": "string" },
                  "meetingType": { "type": "string" },
                  "meetingDate": { "type": "string" },
                  "reportDate": { "type": "string" },
                  "noteText": { "type": "string" },
                  "transcriptText": { "type": "string" },
                  "decisions": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "todos": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/TodoItem" }
                  },
                  "changeOrders": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/ChangeOrderItem" }
                  },
                  "nextAction": { "type": "string" },
                  "summaryStatus": { "type": "string" },
                  "signatureStatus": { "type": "string" },
                  "acceptedScope": { "type": "string" },
                  "exclusions": { "type": "string" },
                  "currentStage": { "type": "string" },
                  "nextStep": { "type": "string" },
                  "progressPct": { "type": "number" },
                  "stageNote": { "type": "string" },
                  "documents": {
                    "type": "object",
                    "properties": {
                      "references": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "transcripts": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "ks": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "photos": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "offers": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "contracts": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "extraWork": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      },
                      "emails": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/DocumentLink" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Meeting package saved"
          }
        }
      }
    },
    "/api/intake": {
      "post": {
        "operationId": "submitCaseIntake",
        "summary": "Save structured case notes and progress",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customerName", "noteText"],
                "properties": {
                  "caseNumber": { "type": "string" },
                  "actorName": { "type": "string" },
                  "actorEmail": { "type": "string" },
                  "customerName": { "type": "string" },
                  "source": { "type": "string" },
                  "meetingType": { "type": "string" },
                  "noteText": { "type": "string" },
                  "transcriptText": { "type": "string" },
                  "decisions": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "todos": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/TodoItem" }
                  },
                  "changeOrders": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/ChangeOrderItem" }
                  },
                  "nextAction": { "type": "string" },
                  "summaryStatus": { "type": "string" },
                  "signatureStatus": { "type": "string" },
                  "acceptedScope": { "type": "string" },
                  "exclusions": { "type": "string" },
                  "currentStage": { "type": "string" },
                  "nextStep": { "type": "string" },
                  "progressPct": { "type": "number" },
                  "stageNote": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Case intake saved"
          }
        }
      }
    },
    "/api/gmail-draft": {
      "post": {
        "operationId": "createGmailDraft",
        "summary": "Create a draft-first customer email record",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customerName", "subject", "body", "recipients"],
                "properties": {
                  "caseNumber": { "type": "string" },
                  "actorName": { "type": "string" },
                  "actorEmail": { "type": "string" },
                  "customerName": { "type": "string" },
                  "type": { "type": "string" },
                  "subject": { "type": "string" },
                  "body": { "type": "string" },
                  "html": { "type": "string" },
                  "recipients": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "cc": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "bcc": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "attachments": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/DraftAttachment" }
                  },
                  "source": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Draft saved"
          }
        }
      }
    },
    "/api/drive-archive": {
      "post": {
        "operationId": "archiveDocumentsToCase",
        "summary": "Archive document references under a case",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customerName", "category", "documents"],
                "properties": {
                  "caseNumber": { "type": "string" },
                  "actorName": { "type": "string" },
                  "actorEmail": { "type": "string" },
                  "customerName": { "type": "string" },
                  "category": {
                    "type": "string",
                    "enum": ["tilbud", "referater", "ks", "billeder", "ekstraarbejde", "betaling", "kontrakter", "transkripter", "mails"]
                  },
                  "folderId": { "type": "string" },
                  "folderName": { "type": "string" },
                  "documents": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/DocumentLink" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Archive references saved"
          }
        }
      }
    }
  }
}
